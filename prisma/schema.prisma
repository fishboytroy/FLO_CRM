generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  platform_admin
  admin
  agent
}

enum OrganizationPlan {
  internal
  individual
  team
}

enum OrganizationStatus {
  active
  trialing
  past_due
  canceled
}

enum MembershipRole {
  owner
  admin
  agent
}

enum SubscriptionStatus {
  none
  trialing
  active
  past_due
  canceled
}

enum LeadDistributionStatus {
  unassigned
  assigned
  claimed
  purchased
  rejected
  expired
}

enum OrganizationZipCodeStatus {
  active
  trialing
  expired
  canceled
}

enum LeadAssignmentReason {
  zip_match
  manual_assignment
  reassignment
  expired_zip
  admin_override
  unpurchased_zip
}

enum LeadType {
  buyer
  seller
  investor
  renter
  unknown
}

enum PipelineStage {
  new_lead
  contacted
  qualified
  appointment_set
  showing_scheduled
  offer_stage
  closed
  lost
}

enum TaskStatus {
  pending
  completed
}

enum ActivityType {
  note
  status_change
  task_created
  task_completed
  lead_created
  lead_updated
  lead_deleted
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          Role      @default(agent)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts                   Account[]
  sessions                   Session[]
  memberships                Membership[]
  assignedLeads              Lead[]                  @relation("AssignedAgent")
  tasks                      Task[]                  @relation("AssignedTasks")
  activities                 Activity[]
  assignmentFromHistories    LeadAssignmentHistory[] @relation("LeadAssignmentFromUser")
  assignmentToHistories      LeadAssignmentHistory[] @relation("LeadAssignmentToUser")
  assignmentCreatedHistories LeadAssignmentHistory[] @relation("LeadAssignmentCreatedBy")
}

model Organization {
  id                   String             @id @default(cuid())
  name                 String
  slug                 String             @unique
  plan                 OrganizationPlan   @default(individual)
  status               OrganizationStatus @default(active)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  subscriptionStatus   SubscriptionStatus @default(none)
  currentPeriodEnd     DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  memberships             Membership[]
  leads                   Lead[]
  tasks                   Task[]
  activities              Activity[]
  zipCodes                OrganizationZipCode[]
  assignmentFromHistories LeadAssignmentHistory[] @relation("LeadAssignmentFromOrganization")
  assignmentToHistories   LeadAssignmentHistory[] @relation("LeadAssignmentToOrganization")

  @@index([plan])
  @@index([status])
}

model OrganizationZipCode {
  id             String                    @id @default(cuid())
  organizationId String
  zipCode        String
  status         OrganizationZipCodeStatus @default(active)
  exclusive      Boolean                   @default(true)
  startsAt       DateTime                  @default(now())
  expiresAt      DateTime?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([zipCode])
  @@index([status])
}

model Membership {
  id             String         @id @default(cuid())
  userId         String
  organizationId String
  role           MembershipRole @default(agent)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([role])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Lead {
  id                 String                 @id @default(cuid())
  organizationId     String
  firstName          String
  lastName           String
  email              String?
  phone              String?
  leadType           LeadType               @default(unknown)
  status             PipelineStage          @default(new_lead)
  source             String?
  assignedAgentId    String?
  distributionStatus LeadDistributionStatus @default(unassigned)
  claimedAt          DateTime?
  exclusiveUntil     DateTime?
  leadPriceCents     Int?
  marketArea         String?
  zipCode            String?
  budgetMin          Int?
  budgetMax          Int?
  desiredLocation    String?
  propertyInterest   String?
  timeframe          String?
  notes              String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  organization      Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignedAgent     User?                   @relation("AssignedAgent", fields: [assignedAgentId], references: [id], onDelete: SetNull)
  tasks             Task[]
  activities        Activity[]
  assignmentHistory LeadAssignmentHistory[]

  @@index([status])
  @@index([organizationId])
  @@index([leadType])
  @@index([distributionStatus])
  @@index([marketArea])
  @@index([zipCode])
  @@index([organizationId, zipCode])
  @@index([source])
  @@index([assignedAgentId])
  @@index([createdAt])
}

model LeadAssignmentHistory {
  id                 String               @id @default(cuid())
  leadId             String
  fromOrganizationId String?
  toOrganizationId   String?
  fromUserId         String?
  toUserId           String?
  zipCode            String?
  reason             LeadAssignmentReason
  message            String?
  createdByUserId    String?
  createdAt          DateTime             @default(now())

  lead             Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  fromOrganization Organization? @relation("LeadAssignmentFromOrganization", fields: [fromOrganizationId], references: [id], onDelete: SetNull)
  toOrganization   Organization? @relation("LeadAssignmentToOrganization", fields: [toOrganizationId], references: [id], onDelete: SetNull)
  fromUser         User?         @relation("LeadAssignmentFromUser", fields: [fromUserId], references: [id], onDelete: SetNull)
  toUser           User?         @relation("LeadAssignmentToUser", fields: [toUserId], references: [id], onDelete: SetNull)
  createdByUser    User?         @relation("LeadAssignmentCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([leadId])
  @@index([zipCode])
  @@index([toOrganizationId])
  @@index([toUserId])
  @@index([createdAt])
}

model Task {
  id             String     @id @default(cuid())
  organizationId String
  leadId         String
  assignedUserId String?
  title          String
  description    String?
  dueDate        DateTime
  status         TaskStatus @default(pending)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lead         Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  assignedUser User?        @relation("AssignedTasks", fields: [assignedUserId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([leadId])
  @@index([assignedUserId])
  @@index([dueDate])
  @@index([status])
}

model Activity {
  id             String       @id @default(cuid())
  organizationId String
  leadId         String
  userId         String?
  type           ActivityType
  message        String
  createdAt      DateTime     @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lead         Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([leadId])
  @@index([userId])
  @@index([createdAt])
}
