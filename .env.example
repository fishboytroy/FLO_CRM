DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lafayette_crm?schema=public"
AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_URL="http://localhost:3000"
CRM_PUBLIC_API_KEY="replace-with-a-long-random-shared-secret"
CRM_ALLOWED_ORIGIN="https://lafayettelouisianarealestate.com"
CRM_PUBLIC_LEAD_RATE_LIMIT_PER_MINUTE="12"
CRM_PUBLIC_LEAD_MAX_BODY_BYTES="32768"
CRM_APP_URL="http://localhost:3000"
CRM_EMAIL_FROM="crm@example.com"
CRM_EMAIL_FROM_NAME="Lafayette Real Estate CRM"
CRM_NOTIFICATION_FALLBACK_EMAIL="admin@example.com"
BREVO_API_KEY=""
ALLOW_PRODUCTION_SEED="false"

# Optional paid ZIP territory validation setup.
# The setup script is dry-run by default and requires PAID_VALIDATION_ENABLE_WRITE=1 before writing.
PAID_VALIDATION_INDIVIDUAL_ZIP="70510"
PAID_VALIDATION_TEAM_ZIP="70518"
PAID_VALIDATION_INDIVIDUAL_OWNER_EMAIL="individual-owner@example.com"
PAID_VALIDATION_TEAM_OWNER_EMAIL="team-owner@example.com"
PAID_VALIDATION_TEAM_ADMIN_EMAIL="team-admin@example.com"
PAID_VALIDATION_TEAM_AGENT_EMAIL="team-agent@example.com"
PAID_VALIDATION_PASSWORD=""
PAID_VALIDATION_ENABLE_WRITE="0"
ALLOW_PRODUCTION_PAID_VALIDATION_SETUP="false"
